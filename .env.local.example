# Copiez ce fichier en .env.local et renseignez vos clés

# NextAuth — générez avec: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here

# Base de données SQLite (locale) — chemin relatif depuis la racine du projet
DATABASE_URL="file:./prisma/dev.db"

# Google OAuth (optionnel) — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
